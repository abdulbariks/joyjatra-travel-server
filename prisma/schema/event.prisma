model Event{
    id String @id @default(uuid(7))

    name String
    description String?
    location String
    price Float
    imageUrl String?
    startDate DateTime
    endDate DateTime
    content String?  @db.Text
    isDeleted Boolean @default(false)
    deletedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // relations
    reviews Review[]

    moderatorId String
    moderator   Moderator @relation(fields: [moderatorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([isDeleted], name: "idx_event_isDeleted")
    @@map("event")
}