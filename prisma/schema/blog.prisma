model Blog {
    id String @id @default(uuid(7))

    title String
    location String
    description String?
    imageUrl String?
    content String?  @db.Text
    isDeleted Boolean @default(false)
    deletedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // relations
    reviews Review[]

    moderatorId String
    moderator   Moderator @relation(fields: [moderatorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@index([isDeleted], name: "idx_blog_isDeleted")
    @@map("blog")
}